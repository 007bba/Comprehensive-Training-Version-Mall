# Copy this file to .env and fill in local values.
# Do not commit .env because it contains secrets.

DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase/PostgreSQL database.
# Get these values from Supabase: Project Settings -> Database -> Connection string.
# Replace <db-password> and <project-ref> with your own values.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-your-region.pooler.supabase.com:5432/postgres?sslmode=require

# Example shape only, do not use this literal value:
# DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-your-region.pooler.supabase.com:5432/postgres?sslmode=require

# Optional legacy MySQL settings. They are kept for reference only;
# current settings.py uses DATABASE_URL when it is provided.
MYSQL_DATABASE=shop
MYSQL_USER=root
MYSQL_PASSWORD=change-this
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
